generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OrthoM8Lead {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Onboarding form answers
  sector        String?
  concerns      Json?
  capitalRange  String?

  // Contact details
  name          String
  email         String
  company       String?
  phone         String?
  callTime      String?
  message       String?    @db.Text

  // Internal tracking
  source        String     @default("orthom8-onboarding")
  status        String     @default("NEW") // NEW, CONTACTED, QUALIFIED, ARCHIVED
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?

  // Email campaign history
  emailLogs     EmailLog[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// Tracks every email sent to every lead — drives follow-up eligibility logic
model EmailLog {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  leadId     String
  lead       OrthoM8Lead @relation(fields: [leadId], references: [id])
  template   String      // cold-outreach | follow-up-1 | follow-up-2 | follow-up-3 | audit-confirmation
  campaignId String
  sentAt     DateTime    @default(now())

  @@index([leadId])
  @@index([template])
  @@index([leadId, template])
}
